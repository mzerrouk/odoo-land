# ══════════════════════════════════════════════════════════════
#  Odoo Local Dev — Single Source of Truth
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your values below
#  3. NEVER commit .env to git (it's in .gitignore)
# ══════════════════════════════════════════════════════════════

# ── Odoo Version ──────────────────────────────────────────────
# Must match your Odoo.sh project version
ODOO_VERSION=16.0

# ── Local Project Folder ──────────────────────────────────────
# Subfolder name where source files & config will be placed
PROJECT_DIR=odoo-local

# ── Odoo.sh Remote SSH ────────────────────────────────────────
# SSH_USER: your numeric Odoo.sh user ID (Settings → SSH Keys)
# SSH_HOST: your project's Odoo.sh domain (e.g. myproject.odoo.com)
SSH_USER=12345678
SSH_HOST=your-project.odoo.com
REMOTE_SRC=/home/odoo/src

# ── Sync Options ──────────────────────────────────────────────
# Set to true to also sync the Odoo core source (~1.5 GB).
# Only needed if your production uses a patched Odoo core.
# When false, the standard Docker image is used instead (recommended).
SYNC_ODOO_CORE=false

# ── Local PostgreSQL ──────────────────────────────────────────
LOCAL_DB_USER=odoo
LOCAL_DB_PASSWORD=odoo
LOCAL_DB_NAME=odoo

# ── Odoo Settings ─────────────────────────────────────────────
# ODOO_PORT: the port exposed on your host machine
ODOO_PORT=8070
ADMIN_PASSWD=admin

# ── User / Custom Modules Repo ────────────────────────────────
# GitHub URL of your custom Odoo modules repo (odoo-local/user/).
# Used to re-initialize git after rsync (Odoo.sh uses worktrees
# which produce a .git *file*, not a directory, that points to
# a server path that doesn't exist locally).
# Example: https://github.com/your-org/your-custom-modules.git
USER_REPO=https://github.com/your-org/your-custom-modules.git

# Branch to track locally (must exist on USER_REPO remote).
# If left empty, the remote's default HEAD branch is used.
USER_BRANCH=main
